# Backend Environment Variables
# Copy this file to .env and fill in the values for your environment

# Database
DATABASE_URL=postgresql://username:password@host/dropout_db

# Security
JWT_SECRET_KEY=your-long-random-secret-key-here

# Development mode
FLASK_APP=run.py
FLASK_ENV=development

# Email (for password resets)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=your-email@gmail.com

# Frontend URLs (for CORS and password reset emails)
FRONTEND_BASE_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Production examples:
# FRONTEND_BASE_URL=https://dropout-system.vercel.app
# FRONTEND_URL=https://dropout-system.vercel.app
